<!DOCTYPE html>
<html>
<head>
  <title>Mini Messageboard</title>
</head>
<body>

<h1><%= title %></h1>

<a href="/new">Add New Message</a>

<ul>
  <% messages.forEach(msg => { %>
    <li>
      <strong><%= msg.user %></strong>: 
      <%= msg.text %> 
      (<%= msg.added.toLocaleString() %>)
    </li>
  <% }) %>
</ul>

</body>
</html>